{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-ignore",
  ],
  "mcp": {
    "ddg-search": {
      "type": "local",
      "command": [
        "uvx",
        "duckduckgo-mcp-server"
      ],
      "enabled": true
    },
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen/qwen3-4b-thinking-2507": {
          "name": "qwen/qwen3-4b-thinking-2507"
        },
      }
    }
  }
}
